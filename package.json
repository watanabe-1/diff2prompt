{
  "name": "diff2prompt",
  "version": "0.0.12",
  "description": "CLI tool for turning Git diffs into AI-ready prompts",
  "keywords": [
    "cli",
    "typescript"
  ],
  "homepage": "https://github.com/watanabe-1/diff2prompt#readme",
  "bugs": {
    "url": "https://github.com/watanabe-1/diff2prompt/issues"
  },
  "license": "MIT",
  "author": "watanabe-1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/watanabe-1/diff2prompt.git"
  },
  "bin": {
    "diff2prompt": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "bun run clean && bun build.ts",
    "clean": "bun -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "test": "vitest run",
    "test:package": "bun run scripts/package-smoke-test.ts",
    "test:coverage": "vitest run --coverage.enabled true",
    "test:ui": "vitest --ui --coverage.enabled true",
    "test:watch": "vitest --watch",
    "lint": "bun run format:oxfmt:check && oxlint .",
    "lint:oxlint": "oxlint .",
    "check:fix": "oxfmt . && oxlint --fix .",
    "format:oxfmt": "oxfmt .",
    "format:oxfmt:check": "oxfmt --check .",
    "typecheck": "tsc --noEmit",
    "diff2prompt": "bun run src/index.ts --exclude=bun.lock --exclude-file=.gitignore"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "esbuild": "^0.28.1",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9"
  }
}
